---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Travel itineraries by Ashi.', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = Astro.url.href;
const resolvedOgImage =
  ogImage ?? new URL(`${base.replace(/\/$/, '')}/og/default.png`, Astro.site).href;
const fontsUrl =
  'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap';

const trimmed = (s: string) => s.replace(/\/$/, '');
const navLinks = [
  { href: `${trimmed(base)}/trips`, label: 'trips' },
  { href: `${trimmed(base)}/visa`, label: 'visa' },
  { href: `${trimmed(base)}/tips`, label: 'tips' },
  { href: `${trimmed(base)}/about`, label: 'about' },
];
const currentPath = trimmed(Astro.url.pathname);
const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="wanderlust" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontsUrl} />
    <link rel="stylesheet" href={fontsUrl} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsUrl} /></noscript>
    <title>{title}</title>
    {import.meta.env.PROD && (
      <script is:inline data-goatcounter="https://wanderlust.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
    )}
  </head>
  <style>
    /* Active nav item: ink colour plus an accent underline so the current
       page is unmistakable, not just a subtle shade difference. */
    .nav-link {
      position: relative;
      padding-bottom: 0.35rem;
    }
    .nav-link--active::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 2px;
      background: var(--color-accent);
    }
  </style>
  <body>
    <header class="border-b" style="border-color: var(--color-line)">
      <div class="mx-auto flex max-w-5xl flex-col gap-3 px-6 py-6 md:flex-row md:items-baseline md:justify-between">
        <a href={base} class="font-display text-xl font-medium tracking-tight">wanderlust</a>
        <nav class="font-mono text-xs uppercase tracking-widest" style="color: var(--color-muted)">
          {navLinks.map((link, i) => (
            <a
              href={link.href}
              class:list={[
                i > 0 && 'ml-6',
                'nav-link hover:text-[color:var(--color-ink)]',
                isActive(link.href) && 'nav-link--active',
              ]}
              style={isActive(link.href) ? 'color: var(--color-ink)' : undefined}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12 md:py-20">
      <slot />
    </main>

    <footer class="mt-24 border-t" style="border-color: var(--color-line)">
      <div class="mx-auto max-w-5xl px-6 py-10">
        <p class="font-mono text-xs uppercase tracking-widest" style="color: var(--color-muted)">
          by ashi &middot;
          <a href="https://instagram.com/aaashi.b" class="inline-flex items-center gap-1.5 align-middle hover:text-[color:var(--color-ink)]">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            @aaashi.b
          </a>
        </p>
      </div>
    </footer>

    <button
      id="to-top"
      type="button"
      aria-label="Back to top"
      class="pointer-events-none fixed bottom-6 right-6 z-50 flex h-11 w-11 items-center justify-center rounded-full border opacity-0 transition-opacity duration-200 hover:border-[color:var(--color-ink)]"
      style="background-color: var(--color-bg); border-color: var(--color-line); color: var(--color-ink); box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08)"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="19" x2="12" y2="5"></line>
        <polyline points="5 12 12 5 19 12"></polyline>
      </svg>
    </button>

    <script>
      const btn = document.getElementById('to-top');
      if (btn) {
        const toggle = () => {
          const show = window.scrollY > 600;
          btn.classList.toggle('opacity-0', !show);
          btn.classList.toggle('pointer-events-none', !show);
        };
        toggle();
        window.addEventListener('scroll', toggle, { passive: true });
        btn.addEventListener('click', () => {
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
        });
      }
    </script>
  </body>
</html>
