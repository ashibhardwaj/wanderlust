---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { feature } from 'topojson-client';
import { geoNaturalEarth1, geoPath } from 'd3-geo';
import worldAtlas from '../data/world-india.topo.json';
import { placeholderCountries } from '../data/placeholders';

const base = import.meta.env.BASE_URL;
const tripHref = (id: string) => `${base.replace(/\/$/, '')}/trips/${id}`;

const trips = (await getCollection('trips', ({ data }) => data.status === 'published'))
  .sort((a, b) => (b.data.trip_date ?? '').localeCompare(a.data.trip_date ?? ''));

// Country name aliases for mismatches between trip frontmatter and world-atlas naming.
// Some entries fold neighbouring micro-countries into a bigger polygon when
// they were visited on the same trip (e.g. Vatican City within Italy,
// Singapore alongside Malaysia). The hover label lists both names.
const countryAlias: Record<string, string> = {
  USA: 'United States of America',
  'United States': 'United States of America',
  UK: 'United Kingdom',
  England: 'United Kingdom',
  Scotland: 'United Kingdom',
  Wales: 'United Kingdom',
  'Northern Ireland': 'United Kingdom',
  UAE: 'United Arab Emirates',
  'Czech Republic': 'Czechia',
  Türkiye: 'Turkey',
  'Vatican City': 'Italy',
  Singapore: 'Malaysia',
};
const canonical = (name: string) => countryAlias[name] ?? name;

type TripRef = { id: string; title: string; cover_color: string; trip_date?: string };
const tripsByCountry = new Map<string, TripRef[]>();
for (const trip of trips) {
  for (const country of trip.data.countries) {
    const key = canonical(country);
    const list = tripsByCountry.get(key) ?? [];
    list.push({
      id: trip.id,
      title: trip.data.title,
      cover_color: trip.data.cover_color,
      trip_date: trip.data.trip_date,
    });
    tripsByCountry.set(key, list);
  }
}
for (const list of tripsByCountry.values()) {
  list.sort((a, b) => (b.trip_date ?? '').localeCompare(a.trip_date ?? ''));
}

const width = 960;
const height = 480;
const fc = feature(worldAtlas as any, (worldAtlas as any).objects.topo) as any;
const projection = geoNaturalEarth1().fitSize([width, height], fc);
const path = geoPath(projection);
// d3-geo emits ~6 decimals of precision by default. At our viewBox + max zoom
// (12x), one decimal is plenty (~0.08px error at max zoom) and shaves a big
// chunk off the inline SVG size, which is where most of the HTML weight comes
// from. Keeps numbers with no decimal point unchanged.
const trimPath = (d: string | null) => (d ?? '').replace(/(\.\d)\d+/g, '$1');

const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const r1 = (n: number) => Math.round(n * 10) / 10;
// Multi-trip countries are filled with thin alternating diagonal stripes, one
// colour per trip, so the fill reads as "more than one trip here" without
// implying any geography (which solid halves did). STRIPE_ANGLE sets the
// direction (45 = diagonal, 0 = horizontal, 90 = vertical); STRIPE_BANDS is the
// band count across the country, so stripe density looks the same regardless of
// how big the country is on the map.
const STRIPE_ANGLE = 45;
const STRIPE_BANDS = 14;
const stripePattern = (bounds: [number, number, number, number], count: number) => {
  const [x0, y0, x1, y1] = bounds;
  const cx = (x0 + x1) / 2;
  const cy = (y0 + y1) / 2;
  // A square of side = bbox diagonal, centred on the bbox, still covers the
  // bbox after rotation, so rotated bands never leave gaps at the corners.
  const diag = Math.hypot(x1 - x0, y1 - y0) || 1;
  const bandH = diag / STRIPE_BANDS;
  const bands = Array.from({ length: STRIPE_BANDS }, (_, i) => ({
    x: r1(cx - diag / 2),
    y: r1(cy - diag / 2 + i * bandH),
    width: r1(diag),
    height: r1(bandH),
    trip: i % count,
  }));
  return { cx: r1(cx), cy: r1(cy), bands };
};

// Build a map: canonical country name -> original list entries that collapse
// to it (e.g. "United Kingdom" -> ["England", "Scotland", "Wales", "Northern
// Ireland"]). Lets the hover label preserve every place name even when
// multiple entries share one polygon.
const placeholderOriginals = new Map<string, string[]>();
for (const original of placeholderCountries) {
  const c = canonical(original);
  const list = placeholderOriginals.get(c) ?? [];
  list.push(original);
  placeholderOriginals.set(c, list);
}
const placeholderSet = new Set(placeholderOriginals.keys());

type Country = {
  name: string;
  d: string;
  trips: TripRef[];
  placeholderLabel: string | null;
  bounds: [number, number, number, number];
};
const countries: Country[] = fc.features.map((f: any) => {
  const name = f.properties.NAME as string;
  const list = tripsByCountry.get(name) ?? [];
  const placeholderLabel =
    list.length === 0 && placeholderSet.has(name)
      ? (placeholderOriginals.get(name) ?? [name]).join(', ')
      : null;
  const [[bx0, by0], [bx1, by1]] = path.bounds(f);
  return {
    name,
    d: trimPath(path(f)),
    trips: list,
    placeholderLabel,
    bounds: [bx0, by0, bx1, by1],
  };
});

// Pin definitions for countries the 110m dataset doesn't draw. Multiple country
// names can share a single pin when they're geographically too close to
// distinguish at world-map scale (e.g. Hong Kong + Macau, ~60km apart). The
// pin's label then lists every name, matching how the UK polygon lists its
// constituents.
//
// A pin can render as either a placeholder (muted shade, "coming soon") or a
// published trip (cover_color, links to the trip detail). When a pin group
// mixes the two (e.g. you've written up Hong Kong but Macau is still
// pending), the label spells out each name's status.
const pinDefinitions: { names: string[]; coords: [number, number] }[] = [
  { names: ['Bahrain'], coords: [50.56, 26.07] },
  { names: ['Hong Kong', 'Macau'], coords: [113.85, 22.26] },
  { names: ['Mauritius'], coords: [57.55, -20.35] },
];

type Pin = { label: string; cx: number; cy: number; fill: string; href: string | null };
const placeholderPins: Pin[] = pinDefinitions
  .map((p) => {
    type Status =
      | { name: string; kind: 'trip'; trips: TripRef[] }
      | { name: string; kind: 'placeholder' };

    const statuses: Status[] = [];
    for (const n of p.names) {
      const canon = canonical(n);
      const t = tripsByCountry.get(canon);
      if (t && t.length > 0) {
        statuses.push({ name: n, kind: 'trip', trips: t });
      } else if (placeholderSet.has(canon)) {
        statuses.push({ name: n, kind: 'placeholder' });
      }
    }
    if (statuses.length === 0) return null;

    // Most-recent trip across the whole pin group decides the fill and link.
    const allTrips = statuses.flatMap((s) => (s.kind === 'trip' ? s.trips : []));
    const recentTrip = allTrips.length > 0
      ? [...allTrips].sort((a, b) => (b.trip_date ?? '').localeCompare(a.trip_date ?? ''))[0]
      : null;

    // Build a suffix per name (trip title(s) or "coming soon"). If every name
    // shares the same suffix, collapse to one combined label; otherwise spell
    // out each status individually so a mixed group reads clearly.
    const suffixes = statuses.map((s) =>
      s.kind === 'trip' ? s.trips.map((t) => t.title).join(', ') : 'coming soon'
    );
    const allSame = suffixes.every((x) => x === suffixes[0]);
    const label = allSame
      ? `${statuses.map((s) => s.name).join(', ')} (${suffixes[0]})`
      : statuses.map((s, i) => `${s.name} (${suffixes[i]})`).join(', ');

    const [x, y] = projection(p.coords)!;
    return {
      label,
      cx: x,
      cy: y,
      fill: recentTrip ? recentTrip.cover_color : 'var(--color-placeholder)',
      href: recentTrip ? tripHref(recentTrip.id) : null,
    };
  })
  .filter((p): p is Pin => p !== null);

const totalCountriesWritten = [...tripsByCountry.keys()].length;
// Count raw entries the user listed, not the polygon count, so UK constituents
// (England, Scotland, Wales, Northern Ireland) count as 4 visited places even
// though they share one polygon.
const totalCountriesPlaceholder = new Set(placeholderCountries).size;
const totalTrips = trips.length;
---

<Layout title="wanderlust · itineraries by ashi">
  <section class="mb-12 max-w-2xl">
    <h1 class="font-display text-4xl font-medium leading-[1.05] tracking-tight md:text-5xl">
      Where I've been.
    </h1>
    <p class="mt-6 text-base leading-relaxed" style="color: var(--color-muted)">
      {totalCountriesWritten} {totalCountriesWritten === 1 ? 'country' : 'countries'} written up across {totalTrips} {totalTrips === 1 ? 'trip' : 'trips'}{totalCountriesPlaceholder > 0 && `, with ${totalCountriesPlaceholder} more on the way`}. Tap a colored country to read its itinerary; shaded ones are coming soon.
    </p>
  </section>

  <div class="border relative" style="border-color: var(--color-line)">
    <svg
      id="world-map"
      viewBox={`0 0 ${width} ${height}`}
      class="block h-auto w-full"
      role="img"
      aria-label="World map highlighting countries with trip itineraries. Use ctrl or cmd plus scroll, or two fingers, to zoom; drag to pan."
    >
      <g class="map-layer">
        {countries.map((c) => (
          c.trips.length > 1 ? (
            <>
              <clipPath id={`clip-${slugify(c.name)}`}>
                <path d={c.d} />
              </clipPath>
              {(() => {
                const sp = stripePattern(c.bounds, c.trips.length);
                return (
                  <g clip-path={`url(#clip-${slugify(c.name)})`}>
                    <g transform={`rotate(${STRIPE_ANGLE} ${sp.cx} ${sp.cy})`}>
                      {c.trips.map((t, ti) => (
                        <a href={tripHref(t.id)} class="stripe-link">
                          <title>{`${c.name} (${t.title})`}</title>
                          {sp.bands
                            .filter((b) => b.trip === ti)
                            .map((b) => (
                              <rect
                                x={b.x}
                                y={b.y}
                                width={b.width}
                                height={b.height}
                                fill={t.cover_color}
                                class="country country--trip"
                              />
                            ))}
                        </a>
                      ))}
                    </g>
                  </g>
                );
              })()}
              <path
                d={c.d}
                fill="none"
                stroke="var(--color-bg)"
                stroke-width="0.5"
                class="country-outline"
              />
            </>
          ) : c.trips.length === 1 ? (
            <a href={tripHref(c.trips[0].id)}>
              <path
                d={c.d}
                fill={c.trips[0].cover_color}
                stroke="var(--color-bg)"
                stroke-width="0.5"
                class="country country--trip"
              >
                <title>{`${c.name} (${c.trips[0].title})`}</title>
              </path>
            </a>
          ) : c.placeholderLabel ? (
            <path
              d={c.d}
              fill="var(--color-placeholder)"
              stroke="var(--color-bg)"
              stroke-width="0.5"
              class="country country--placeholder"
            >
              <title>{`${c.placeholderLabel} (coming soon)`}</title>
            </path>
          ) : (
            <path
              d={c.d}
              fill="var(--color-line)"
              stroke="var(--color-bg)"
              stroke-width="0.5"
              class="country"
            >
              <title>{c.name}</title>
            </path>
          )
        ))}
        {placeholderPins.map((p) => (
          p.href ? (
            <a href={p.href}>
              <circle
                cx={p.cx}
                cy={p.cy}
                r={2.5}
                fill={p.fill}
                stroke="var(--color-bg)"
                stroke-width="0.5"
                class="country country--trip"
              >
                <title>{p.label}</title>
              </circle>
            </a>
          ) : (
            <circle
              cx={p.cx}
              cy={p.cy}
              r={2.5}
              fill={p.fill}
              stroke="var(--color-bg)"
              stroke-width="0.5"
              class="country country--placeholder"
            >
              <title>{p.label}</title>
            </circle>
          )
        ))}
      </g>
    </svg>
    <div class="zoom-controls">
      <button id="zoom-in" aria-label="Zoom in" title="Zoom in">+</button>
      <button id="zoom-out" aria-label="Zoom out" title="Zoom out">−</button>
    </div>
  </div>

  {totalTrips > 0 && (
    <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2">
      {trips.map((t) => (
        <li class="flex items-center gap-2">
          <span class="inline-block h-3 w-3" style={`background-color: ${t.data.cover_color}`}></span>
          <a
            href={tripHref(t.id)}
            class="font-mono text-xs uppercase tracking-widest hover:text-[color:var(--color-ink)]"
            style="color: var(--color-muted)"
          >
            {t.data.title}
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>

<style>
  #world-map {
    cursor: grab;
    /* Allow normal vertical page scroll over the map; the zoom filter below
       reserves two-finger / ctrl+wheel for actually zooming the map. */
    touch-action: pan-y;
  }
  #world-map:active {
    cursor: grabbing;
  }
  .zoom-controls {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .zoom-controls button {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    line-height: 1;
    background: var(--color-bg);
    color: var(--color-ink);
    border: 1px solid var(--color-line);
    cursor: pointer;
    user-select: none;
    transition: background 0.1s ease;
  }
  .zoom-controls button:hover {
    background: var(--color-line);
  }
  .country {
    transition: opacity 0.15s ease;
  }
  .country--trip:hover {
    opacity: 0.7;
    cursor: pointer;
  }
  /* Redrawn border for striped (multi-trip) countries; must not eat stripe clicks. */
  .country-outline {
    pointer-events: none;
  }
  /* Hovering any stripe of a trip dims that trip's whole set together. */
  .stripe-link {
    cursor: pointer;
  }
  .stripe-link:hover .country--trip {
    opacity: 0.7;
  }
</style>

<script>
  import { select } from 'd3-selection';
  import { zoom } from 'd3-zoom';

  const svgEl = document.getElementById('world-map');
  if (svgEl) {
    const vb = svgEl.getAttribute('viewBox')!.split(/\s+/).map(Number);
    const [, , w, h] = vb;
    const svg = select(svgEl as unknown as Element);
    const layer = svg.select('g.map-layer');
    let currentScale = 1;
    const zoomBehavior = zoom<SVGSVGElement, unknown>()
      .scaleExtent([1, 12])
      .translateExtent([[0, 0], [w, h]])
      // Don't hijack the page: wheel zooms only with ctrl/cmd. Touch requires
      // two fingers at scale 1 (so one-finger swipe still scrolls the page),
      // but once the user has zoomed in, one finger can pan the map freely.
      .filter((event: any) => {
        if (event.type === 'wheel') return event.ctrlKey || event.metaKey;
        if (event.type === 'touchstart') return event.touches.length >= 2 || currentScale > 1;
        return true;
      })
      .on('zoom', (event) => {
        currentScale = event.transform.k;
        // Allow one-finger pan when zoomed in; restore page scroll at scale 1.
        (svgEl as HTMLElement).style.touchAction = currentScale > 1 ? 'none' : 'pan-y';
        layer.attr('transform', event.transform.toString());
      });
    svg.call(zoomBehavior as any);

    const zoomBy = (factor: number) => {
      svg.transition().duration(250).call(
        (zoomBehavior as any).scaleBy,
        factor
      );
    };

    document.getElementById('zoom-in')?.addEventListener('click', () => zoomBy(2));
    document.getElementById('zoom-out')?.addEventListener('click', () => zoomBy(0.5));
  }
</script>
